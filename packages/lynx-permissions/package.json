{
    "name": "@sigx/lynx-permissions",
    "version": "0.4.0",
    "description": "Shared Android permission helper for sigx-lynx native modules",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./signalx-module.json": "./signalx-module.json"
    },
    "files": [
        "dist",
        "android",
        "signalx-module.json"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "prepublishOnly": "vite build && tsgo --emitDeclarationOnly",
        "clean": "rm -rf dist .turbo *.tsbuildinfo"
    },
    "devDependencies": {
        "@sigx/vite": "^0.4.8",
        "@typescript/native-preview": "7.0.0-dev.20260511.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.14"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-permissions"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-permissions",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "mobile",
        "ios",
        "android",
        "permissions"
    ]
}
