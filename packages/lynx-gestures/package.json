{
    "name": "@sigx/lynx-gestures",
    "version": "0.20.0",
    "description": "Gesture system for sigx-lynx - declarative composables for tap, pan, pinch, swipe, long press",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./signalx-module.json": "./signalx-module.json",
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "dist",
        "ios",
        "android",
        "signalx-module.json"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "prepublishOnly": "node ../../scripts/clean.mjs dist && tsgo",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "lynx",
        "gestures",
        "touch",
        "pan",
        "pinch",
        "swipe",
        "reactive"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "dependencies": {
        "@sigx/lynx": "workspace:^"
    },
    "devDependencies": {
        "@lynx-js/react": "^0.121.0",
        "@sigx/lynx-plugin": "workspace:^",
        "@sigx/lynx-runtime-main": "workspace:^",
        "@sigx/lynx-testing": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-gestures"
    },
    "homepage": "https://sigx.dev/lynx/modules/gestures/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
