{
    "name": "@sigx/lynx-linking",
    "version": "0.4.3",
    "description": "Deep links and URL scheme handling for sigx-lynx",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./router": {
            "import": "./dist/router.js",
            "types": "./dist/router.d.ts"
        },
        "./signalx-module.json": "./signalx-module.json"
    },
    "files": [
        "dist",
        "ios",
        "android",
        "signalx-module.json"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "test": "vitest run",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "dependencies": {
        "@sigx/lynx-core": "workspace:^"
    },
    "peerDependencies": {
        "@sigx/router": "^0.3.2",
        "sigx": "^0.4.1"
    },
    "peerDependenciesMeta": {
        "@sigx/router": {
            "optional": true
        },
        "sigx": {
            "optional": true
        }
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-linking"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-linking",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "mobile",
        "ios",
        "android",
        "linking"
    ]
}
