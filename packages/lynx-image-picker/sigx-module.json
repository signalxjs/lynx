{
    "name": "ImagePicker",
    "package": "@sigx/lynx-image-picker",
    "description": "Gallery image/video picker",
    "platforms": ["android", "ios"],
    "ios": {
        "moduleClass": "ImagePickerModule",
        "sourceDir": "ios",
        "methods": ["pickImage","pickVideo","requestPermission","getPermissionStatus"],
        "usageDescriptions": {
            "NSPhotoLibraryUsageDescription": "Allow photo library access to pick images and videos."
        }
    },
    "android": {
        "moduleClass": "com.sigx.imagepicker.ImagePickerModule",
        "sourceDir": "android",
        "permissions": ["android.permission.READ_MEDIA_IMAGES","android.permission.READ_MEDIA_VIDEO","android.permission.READ_EXTERNAL_STORAGE"]
    }
}
