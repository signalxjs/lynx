{
    "name": "@sigx/lynx-image-picker",
    "version": "0.4.0",
    "description": "Image picker for sigx-lynx",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./signalx-module.json": "./signalx-module.json"
    },
    "files": [
        "dist",
        "ios",
        "android",
        "signalx-module.json"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch"
    },
    "dependencies": {
        "@sigx/lynx-core": "workspace:^"
    },
    "devDependencies": {
        "typescript": "^6.0.3",
        "@sigx/vite": "^0.4.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-image-picker"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-image-picker",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "mobile",
        "ios",
        "android",
        "image-picker"
    ]
}
