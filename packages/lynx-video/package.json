{
    "name": "@sigx/lynx-video",
    "version": "0.12.0",
    "description": "Native video player component for sigx-lynx (AVPlayer on iOS, ExoPlayer on Android).",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./signalx-module.json": "./signalx-module.json",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "ios",
        "android",
        "signalx-module.json",
        "README.md"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "peerDependencies": {
        "@sigx/lynx": "workspace:^"
    },
    "devDependencies": {
        "@sigx/lynx": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-video"
    },
    "homepage": "https://sigx.dev/lynx/modules/video/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "video",
        "avplayer",
        "exoplayer",
        "ios",
        "android"
    ]
}
