{
    "name": "@sigx/lynx-dev-client",
    "version": "0.4.0",
    "description": "Dev client for sigx-lynx — resource fetchers, template provider, and devtool integration",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./install": {
            "import": "./dist/install.js",
            "types": "./dist/install.d.ts",
            "default": "./dist/install.js"
        },
        "./signalx-module.json": "./signalx-module.json",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "android",
        "ios",
        "signalx-module.json"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch"
    },
    "dependencies": {
        "@sigx/lynx-websocket": "workspace:^"
    },
    "devDependencies": {
        "typescript": "^6.0.3",
        "@sigx/vite": "^0.4.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-dev-client"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-dev-client",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "mobile",
        "ios",
        "android",
        "dev-client"
    ]
}
