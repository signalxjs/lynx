{
    "name": "SigxCore",
    "package": "@sigx/lynx-core",
    "description": "Shared native helpers (Activity holder + presentation + device info) for sigx-lynx modules",
    "platforms": ["android", "ios"],
    "android": {
        "moduleClass": "com.sigx.core.DeviceInfoModule",
        "publisherClass": "com.sigx.core.AppStatePublisher",
        "activityHook": {
            "class": "com.sigx.core.SigxActivityHook",
            "methods": ["onCreate", "onResume", "onPause"]
        },
        "sourceDir": "android"
    },
    "ios": {
        "moduleClass": "DeviceInfoModule",
        "publisherClass": "AppStatePublisher",
        "methods": ["getDeviceInfo", "getConstants", "getAppState"],
        "sourceDir": "ios"
    }
}
