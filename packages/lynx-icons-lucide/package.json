{
    "name": "@sigx/lynx-icons-lucide",
    "version": "0.9.1",
    "description": "Lucide adapter for @sigx/lynx-icons. SVG-mode only — lucide is not distributed as a font.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./components": {
            "types": "./dist/components.d.ts",
            "import": "./dist/components.js",
            "default": "./dist/components.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "peerDependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-icons": "workspace:^",
        "lucide": "^1.0.0"
    },
    "devDependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-icons": "workspace:^",
        "@types/node": "^25.9.3",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "lucide": "^1.16.0",
        "typescript": "^6.0.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-icons-lucide"
    },
    "homepage": "https://sigx.dev/lynx/modules/icons-lucide/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "icon",
        "lucide"
    ]
}
