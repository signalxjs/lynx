{
    "name": "@sigx/lynx-heroui",
    "version": "0.18.0",
    "description": "HeroUI-flavored design system for sigx-lynx, built on the @sigx/lynx-zero foundation — pilot scope while the shared contract is validated",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./preset": {
            "types": "./dist/preset/index.d.ts",
            "import": "./dist/preset/index.js",
            "default": "./dist/preset/index.js"
        },
        "./navigation": {
            "types": "./dist/navigation.d.ts",
            "import": "./dist/navigation.js"
        },
        "./styles": {
            "types": "./dist/styles/index.css.d.ts",
            "default": "./dist/styles/index.css"
        }
    },
    "files": [
        "src",
        "dist"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo && node ../../scripts/copy-assets.mjs src/styles dist/styles && node scripts/gen-theme-css.mjs",
        "dev": "tsgo --watch",
        "prepublishOnly": "node ../../scripts/clean.mjs dist && tsgo && node ../../scripts/copy-assets.mjs src/styles dist/styles && node scripts/gen-theme-css.mjs",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "lynx",
        "heroui",
        "ui",
        "design-system"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "dependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-gestures": "workspace:^",
        "@sigx/lynx-icons": "workspace:^",
        "@sigx/lynx-motion": "workspace:^",
        "@sigx/lynx-zero": "workspace:^"
    },
    "peerDependencies": {
        "@sigx/lynx-navigation": "workspace:^",
        "tailwindcss": "^3.0.0 || ^4.0.0"
    },
    "peerDependenciesMeta": {
        "@sigx/lynx-navigation": {
            "optional": true
        },
        "tailwindcss": {
            "optional": true
        }
    },
    "devDependencies": {
        "@sigx/lynx-navigation": "workspace:^",
        "@sigx/lynx-testing": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-heroui"
    },
    "homepage": "https://sigx.dev/lynx/modules/heroui/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
