{
    "name": "@sigx/lynx-icons",
    "version": "0.18.1",
    "description": "Icon component and registry for sigx-lynx \u2014 works with adapter packages like @sigx/lynx-icons-fa-free and @sigx/lynx-icons-lucide.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./context": {
            "types": "./dist/context.d.ts",
            "import": "./dist/context.js",
            "default": "./dist/context.js"
        },
        "./__codepoints": {
            "types": "./dist/stubs/codepoints.d.ts",
            "import": "./dist/stubs/codepoints.js",
            "default": "./dist/stubs/codepoints.js"
        },
        "./__svgs": {
            "types": "./dist/stubs/svgs.d.ts",
            "import": "./dist/stubs/svgs.js",
            "default": "./dist/stubs/svgs.js"
        },
        "./__font-face.css": {
            "types": "./dist/stubs/font-face.css.d.ts",
            "default": "./dist/stubs/font-face.css"
        },
        "./signalx-module.json": "./signalx-module.json",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "signalx-module.json",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo && node ../../scripts/copy-assets.mjs src/stubs dist/stubs",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "peerDependencies": {
        "@sigx/lynx": "workspace:^"
    },
    "devDependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-testing": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-icons"
    },
    "homepage": "https://sigx.dev/lynx/modules/icons/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "icon",
        "icons",
        "font-awesome",
        "lucide"
    ]
}
