{
    "name": "@sigx/lynx-testing",
    "version": "0.8.0",
    "description": "Testing utilities for SignalX Lynx components - render, fireEvent, queries",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./mt": {
            "import": "./dist/mt/index.js",
            "types": "./dist/mt/index.d.ts"
        },
        "./mt/setup": {
            "import": "./dist/mt/setup.js",
            "types": "./dist/mt/setup.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "testing",
        "lynx",
        "test-renderer"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "dependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/runtime-core": "^0.7.0"
    },
    "peerDependencies": {
        "@lynx-js/react": "^0.121.0",
        "@sigx/lynx-runtime-main": "workspace:^",
        "vitest": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "@lynx-js/react": {
            "optional": true
        },
        "@sigx/lynx-runtime-main": {
            "optional": true
        },
        "vitest": {
            "optional": true
        }
    },
    "devDependencies": {
        "@lynx-js/react": "^0.121.0",
        "@sigx/lynx-runtime-main": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-testing"
    },
    "homepage": "https://sigx.dev/lynx/modules/testing/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
