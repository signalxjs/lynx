{
    "name": "@sigx/lynx-runtime-main",
    "version": "0.21.0",
    "description": "Main Thread (Lepus) entry and ops applier for SignalX Lynx renderer",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": true,
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./entry-main": {
            "import": "./dist/entry-main.js",
            "types": "./dist/entry-main.d.ts"
        },
        "./install-hybrid-worklet": {
            "import": "./dist/install-hybrid-worklet.js",
            "types": "./dist/install-hybrid-worklet.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "THIRD_PARTY_NOTICES.md"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "lynx",
        "main-thread"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-runtime-main"
    },
    "homepage": "https://sigx.dev/lynx/modules/runtime-main/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "dependencies": {
        "@sigx/lynx-runtime-internal": "workspace:*"
    },
    "peerDependencies": {
        "@lynx-js/types": ">=3.0.0"
    },
    "peerDependenciesMeta": {
        "@lynx-js/types": {
            "optional": true
        }
    },
    "devDependencies": {
        "@lynx-js/types": "^3.9.0",
        "@sigx/lynx-runtime": "workspace:*",
        "@sigx/runtime-core": "catalog:",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
