{
  "name": "@sigx/lynx-navigation",
  "version": "0.1.0",
  "description": "Type-first native stack router for sigx-lynx",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "echo \"@sigx/lynx-navigation: deferred to post-v0.1 (depends on @sigx/motion)\" && exit 0",
    "dev": "tsc --emitDeclarationOnly --watch",
    "test": "vitest run",
    "test:types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sigx/lynx": "workspace:^",
    "@sigx/lynx-linking": "workspace:^",
    "@sigx/motion": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@sigx/lynx-linking": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sigx/lynx": "workspace:^",
    "@sigx/lynx-linking": "workspace:^",
    "@sigx/lynx-testing": "workspace:^",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "author": "Andreas Ekdahl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signalxjs/lynx.git",
    "directory": "packages/lynx-navigation"
  },
  "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-navigation",
  "bugs": {
    "url": "https://github.com/signalxjs/lynx/issues"
  },
  "private": true
}
