{
    "name": "@sigx/lynx-cli",
    "version": "0.4.9",
    "description": "Lynx CLI plugin for sigx — config, prebuild, auto-linking",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sigx-cli": {
        "plugin": "./dist/plugin.js"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./config": {
            "import": "./dist/config/index.js",
            "types": "./dist/config/index.d.ts"
        }
    },
    "files": [
        "dist",
        "templates"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "dependencies": {
        "@lynx-js/web-core": "^0.20.4",
        "@sigx/cli": "^0.2.8",
        "@sigx/lynx-core": "workspace:^",
        "esbuild": "^0.28.0",
        "sharp": "^0.34.0",
        "ws": "^8.20.1"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@types/ws": "^8.18.1",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-cli"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-cli",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "cli",
        "plugin",
        "mobile",
        "ios",
        "android"
    ],
    "publishConfig": {
        "access": "public"
    }
}
