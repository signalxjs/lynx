source 'https://cdn.cocoapods.org/'

platform :ios, '{{deploymentTarget}}'

install! 'cocoapods',
  :deterministic_uuids => false,
  :generate_multiple_pod_projects => true

target '{{appName}}' do
  use_frameworks! :linkage => :static

  # Lynx Engine
  pod 'Lynx', '3.8.0', :subspecs => ['Framework']
  pod 'PrimJS', '3.8.0', :subspecs => ['quickjs', 'napi']

  # Lynx Services (Devtool subspec ships in all configs — activation is gated
  # at runtime by SigxDevClient.registerServices() inside #if DEBUG).
  pod 'LynxService', '3.8.0', :subspecs => [
    'Image',
    'Log',
    'Http',
    'Devtool',
  ]

  # Extended elements
  pod 'XElement', '3.8.0'

  # Image loading (required by Lynx image service)
  pod 'SDWebImage', '5.15.5'
  pod 'SDWebImageWebPCoder', '0.11.0'

  # {{POD_ENTRIES}}

  # {{DEBUG_POD_ENTRIES}}

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '{{deploymentTarget}}'
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end

    # Lynx's vendored C++ core uses C99 designated/array initializers that
    # Xcode 26's clang flags as -Wc99-designator; the pod compiles with -Werror,
    # so the archive aborts on it. Silence just that one warning across every pod
    # target. Pods that compile from source (Lynx) live in their own subprojects
    # when generate_multiple_pod_projects is on, so cover those too.
    projects = [installer.pods_project]
    projects += installer.pod_target_subprojects if installer.respond_to?(:pod_target_subprojects)
    projects.each do |project|
      project.targets.each do |target|
        target.build_configurations.each do |config|
          flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
          flags = [flags] unless flags.is_a?(Array)
          flags << '-Wno-c99-designator' unless flags.include?('-Wno-c99-designator')
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags
        end
      end
    end
  end
end
