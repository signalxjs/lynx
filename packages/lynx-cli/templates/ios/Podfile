source 'https://cdn.cocoapods.org/'

platform :ios, '{{deploymentTarget}}'

install! 'cocoapods',
  :deterministic_uuids => false,
  :generate_multiple_pod_projects => true

target '{{appName}}' do
  use_frameworks! :linkage => :static

  # Lynx Engine
  pod 'Lynx', '3.7.0', :subspecs => ['Framework']
  pod 'PrimJS', '3.7.0', :subspecs => ['quickjs', 'napi']

  # Lynx Services (Devtool subspec ships in all configs — activation is gated
  # at runtime by SigxDevClient.registerServices() inside #if DEBUG).
  pod 'LynxService', '3.7.0', :subspecs => [
    'Image',
    'Log',
    'Http',
    'Devtool',
  ]

  # Extended elements
  pod 'XElement', '3.7.0'

  # Image loading (required by Lynx image service)
  pod 'SDWebImage', '5.15.5'
  pod 'SDWebImageWebPCoder', '0.11.0'

  # {{POD_ENTRIES}}

  # {{DEBUG_POD_ENTRIES}}

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '{{deploymentTarget}}'
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end

    # LynxServiceAPI 3.7.0's published podspec hardcodes the upstream CI
    # runner path (`/Users/runner/work/lynx/lynx/lynx`) as its only
    # HEADER_SEARCH_PATHS entry, so `#include <service_api/service_api.h>`
    # fails on every consumer machine. Fixed upstream in 3.8.0-rc.0;
    # until that ships stable, patch the generated xcconfig directly —
    # build_settings overrides on the project target don't propagate
    # because the pod's xcconfig has higher precedence.
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files/LynxServiceAPI/*.xcconfig')).each do |xcconfig|
      contents = File.read(xcconfig)
      patched = contents.gsub(
        %r{^HEADER_SEARCH_PATHS = (.*)$},
        'HEADER_SEARCH_PATHS = \1 "${PODS_TARGET_SRCROOT}"',
      )
      File.write(xcconfig, patched) if patched != contents
    end
  end
end
