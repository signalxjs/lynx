<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only override of the release network security config: the dev
     client talks plaintext HTTP to the rspeedy dev server on the LAN, so
     cleartext must be permitted in debug builds. The debug source set's
     resource shadows src/main's strict copy of the same file. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
