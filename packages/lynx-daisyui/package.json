{
    "name": "@sigx/lynx-daisyui",
    "version": "0.1.3",
    "description": "DaisyUI integration for sigx-lynx",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./preset": {
            "types": "./dist/preset/index.d.ts",
            "import": "./dist/preset/index.js",
            "default": "./dist/preset/index.js"
        },
        "./styles": {
            "types": "./dist/styles/index.css.d.ts",
            "default": "./dist/styles/index.css"
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-daisyui"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-daisyui",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly && node ../../scripts/copy-assets.mjs src/styles dist/styles",
        "dev": "vite build --watch",
        "clean": "rm -rf dist .turbo *.tsbuildinfo"
    },
    "dependencies": {
        "@sigx/lynx": "workspace:^"
    },
    "peerDependencies": {
        "@sigx/lynx-navigation": "workspace:^",
        "tailwindcss": "^3.0.0 || ^4.0.0"
    },
    "peerDependenciesMeta": {
        "@sigx/lynx-navigation": {
            "optional": true
        }
    },
    "devDependencies": {
        "@sigx/lynx-navigation": "workspace:^",
        "@sigx/vite": "^0.4.3",
        "@typescript/native-preview": "7.0.0-dev.20260511.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.12"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "daisyui",
        "components",
        "ui"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT"
}
