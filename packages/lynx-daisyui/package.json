{
    "name": "@sigx/lynx-daisyui",
    "version": "0.7.0",
    "description": "DaisyUI integration for sigx-lynx",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./preset": {
            "types": "./dist/preset/index.d.ts",
            "import": "./dist/preset/index.js",
            "default": "./dist/preset/index.js"
        },
        "./styles": {
            "types": "./dist/styles/index.css.d.ts",
            "default": "./dist/styles/index.css"
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-daisyui"
    },
    "homepage": "https://sigx.dev/lynx/modules/daisyui/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo && node ../../scripts/copy-assets.mjs src/styles dist/styles && node scripts/gen-theme-css.mjs",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "dependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-appearance": "workspace:^",
        "@sigx/lynx-gestures": "workspace:^",
        "@sigx/lynx-icons": "workspace:^",
        "@sigx/lynx-motion": "workspace:^",
        "@sigx/lynx-zero": "workspace:^"
    },
    "peerDependencies": {
        "@sigx/lynx-emoji": "workspace:^",
        "@sigx/lynx-markdown": "workspace:^",
        "@sigx/lynx-navigation": "workspace:^",
        "tailwindcss": "^3.0.0 || ^4.0.0"
    },
    "peerDependenciesMeta": {
        "@sigx/lynx-emoji": {
            "optional": true
        },
        "@sigx/lynx-markdown": {
            "optional": true
        },
        "@sigx/lynx-navigation": {
            "optional": true
        }
    },
    "devDependencies": {
        "@sigx/lynx-emoji": "workspace:^",
        "@sigx/lynx-markdown": "workspace:^",
        "@sigx/lynx-navigation": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "daisyui",
        "components",
        "ui"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT"
}
