{
    "name": "@sigx/lynx-updates-publisher",
    "version": "0.11.0",
    "description": "Programmatic OTA publish for @sigx/lynx-updates — package a built .lynx.bundle into the static-manifest layout from CI, no shelling out",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "devDependencies": {
        "@sigx/lynx-updates": "workspace:^",
        "@types/node": "^26.0.1",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-updates-publisher"
    },
    "homepage": "https://sigx.dev/lynx/modules/updates/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "mobile",
        "ios",
        "android",
        "ota",
        "updates",
        "ci",
        "publish"
    ]
}
