{
    "name": "@sigx/lynx-runtime-internal",
    "version": "0.11.0",
    "description": "Shared op types for SignalX Lynx renderer (BG ↔ MTS wire protocol)",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "lynx",
        "internal",
        "ops"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-runtime-internal"
    },
    "homepage": "https://sigx.dev/lynx/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
