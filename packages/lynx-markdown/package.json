{
    "name": "@sigx/lynx-markdown",
    "version": "0.14.0",
    "description": "SignalX-native streaming markdown renderer for Lynx. Parses markdown in JS (zero deps) and renders to native <view>/<text> primitives, with incremental streaming for AI output.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./editor": {
            "types": "./dist/editor/index.d.ts",
            "import": "./dist/editor/index.js",
            "default": "./dist/editor/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "test": "vitest run",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "peerDependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-keyboard": "workspace:^",
        "@sigx/lynx-richtext": "workspace:^"
    },
    "peerDependenciesMeta": {
        "@sigx/lynx-keyboard": {
            "optional": true
        },
        "@sigx/lynx-richtext": {
            "optional": true
        }
    },
    "devDependencies": {
        "@sigx/lynx": "workspace:^",
        "@sigx/lynx-keyboard": "workspace:^",
        "@sigx/lynx-richtext": "workspace:^",
        "@sigx/lynx-testing": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-markdown"
    },
    "homepage": "https://sigx.dev/lynx/modules/markdown/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "markdown",
        "native",
        "streaming",
        "ai"
    ]
}
