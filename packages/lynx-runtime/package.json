{
    "name": "@sigx/lynx-runtime",
    "version": "0.8.0",
    "description": "Lynx renderer for SignalX (background thread)",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./hmr": {
            "import": "./dist/hmr.js",
            "types": "./dist/hmr.d.ts"
        },
        "./mt-hmr-bridge": {
            "import": "./dist/mt-hmr-bridge.js",
            "types": "./dist/mt-hmr-bridge.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "test": "vitest run",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "lynx",
        "renderer"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-runtime"
    },
    "homepage": "https://sigx.dev/lynx/modules/runtime/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "dependencies": {
        "@sigx/lynx-runtime-internal": "workspace:^",
        "@sigx/reactivity": "^0.7.0",
        "@sigx/runtime-core": "^0.7.0"
    },
    "peerDependencies": {
        "@lynx-js/types": "*"
    },
    "peerDependenciesMeta": {
        "@lynx-js/types": {
            "optional": true
        }
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    },
    "publishConfig": {
        "access": "public"
    }
}
