{
    "name": "@sigx/lynx-motion",
    "version": "0.21.0",
    "description": "Animation primitives for sigx-lynx — spring/tween drivers built on SharedValue",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "src",
        "dist"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo",
        "dev": "tsgo --watch",
        "prepublishOnly": "node ../../scripts/clean.mjs dist && tsgo",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "keywords": [
        "sigx",
        "lynx",
        "animation",
        "spring",
        "tween",
        "motion"
    ],
    "author": "Andreas Ekdahl",
    "license": "(MIT AND Apache-2.0)",
    "dependencies": {
        "@sigx/lynx": "workspace:^"
    },
    "devDependencies": {
        "@lynx-js/react": "^0.121.0",
        "@sigx/lynx-plugin": "workspace:^",
        "@sigx/lynx-runtime-main": "workspace:^",
        "@typescript/native-preview": "7.0.0-dev.20260521.1",
        "typescript": "^6.0.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-motion"
    },
    "homepage": "https://sigx.dev/lynx/modules/motion/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
