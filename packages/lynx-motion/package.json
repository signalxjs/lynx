{
    "name": "@sigx/lynx-motion",
    "version": "0.1.2",
    "description": "Animation primitives for sigx-lynx — spring/tween drivers built on SharedValue",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "src",
        "dist"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "prepublishOnly": "vite build && tsgo --emitDeclarationOnly"
    },
    "keywords": [
        "sigx",
        "lynx",
        "animation",
        "spring",
        "tween",
        "motion"
    ],
    "author": "Andreas Ekdahl",
    "license": "(MIT AND Apache-2.0)",
    "dependencies": {
        "@sigx/lynx": "workspace:^"
    },
    "devDependencies": {
        "@lynx-js/react": "^0.119.0",
        "@sigx/lynx-plugin": "workspace:^",
        "@sigx/lynx-runtime-main": "workspace:^",
        "typescript": "^6.0.3",
        "vite": "^8.0.13"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx-motion"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx-motion",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
