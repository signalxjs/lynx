{
    "name": "@sigx/lynx",
    "version": "0.4.0",
    "description": "sigx-lynx framework",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./jsx-runtime": {
            "types": "./dist/jsx-runtime.d.ts",
            "import": "./dist/jsx-runtime.js"
        },
        "./jsx-dev-runtime": {
            "types": "./dist/jsx-dev-runtime.d.ts",
            "import": "./dist/jsx-dev-runtime.js"
        },
        "./client": {
            "types": "./dist/client.d.ts"
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/lynx.git",
        "directory": "packages/lynx"
    },
    "homepage": "https://github.com/signalxjs/lynx/tree/main/packages/lynx",
    "bugs": {
        "url": "https://github.com/signalxjs/lynx/issues"
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node ../../scripts/clean.mjs dist && tsgo && node ../../scripts/copy-assets.mjs src/client.d.ts dist/client.d.ts",
        "dev": "tsgo --watch",
        "clean": "node ../../scripts/clean.mjs dist .turbo"
    },
    "dependencies": {
        "@sigx/reactivity": "^0.4.8",
        "@sigx/runtime-core": "^0.4.8",
        "@sigx/lynx-runtime": "workspace:^"
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260511.1",
        "typescript": "^6.0.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "signalx",
        "sigx",
        "lynx",
        "framework",
        "reactive",
        "cross-platform",
        "mobile",
        "native"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT"
}
