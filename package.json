{
  "name": "sigx-lynx-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "description": "SignalX for Lynx — native mobile framework, runtime, CLI plugin, and native modules",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint packages",
    "lint:fix": "oxlint --fix packages",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules pnpm-lock.yaml",
    "publish:dry": "node scripts/publish.js --dry-run",
    "publish:all": "node scripts/publish.js",
    "publish:beta": "node scripts/publish.js --tag beta",
    "version:set": "node scripts/bump-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "@vitest/coverage-v8": "^4.1.5",
    "oxlint": "^1.47.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "SignalX",
    "sigx",
    "lynx",
    "native",
    "mobile",
    "android",
    "ios"
  ],
  "author": "Andreas Ekdahl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signalxjs/lynx.git"
  },
  "homepage": "https://github.com/signalxjs/lynx",
  "bugs": {
    "url": "https://github.com/signalxjs/lynx/issues"
  },
  "pnpm": {}
}
