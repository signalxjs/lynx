# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.gradle/
*.d.ts
*.d.ts.map
*.js.map

# Keep config + script JS
!vite.config.js
!*.config.js
!packages/*/scripts/*.js
!scripts/*.js

# Source-authored .d.ts (ambient declarations / shims) live alongside
# tsgo-emitted .d.ts files — keep these tracked.
!packages/*/src/shims.d.ts

# TypeScript cache
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.sw?

